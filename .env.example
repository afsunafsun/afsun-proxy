# =============================================================================
# afsun-proxy v2 — скопируйте: cp .env.example .env
# НИКОГДА не коммитьте .env в git
# =============================================================================

# --- Версии ---
XUI_VERSION=3.4.0
CADDY_VERSION=2.9

# --- Домен (ОБЯЗАТЕЛЬНО замените перед install.sh) ---
PROXY_DOMAIN=proxy.example.com
CADDY_EMAIL=admin@example.com

# --- Данные на хосте ---
DATA_DIR=/var/lib/afsun-proxy

# --- 3X-UI (слушает только localhost, снаружи — Caddy :8443) ---
XUI_PORT=2053

# --- VLESS Reality (scripts/setup-vless-inbound.sh / bootstrap.sh) ---
# CLIENT_EMAIL=admin@proxy.example.com
# REALITY_TARGET=www.yahoo.com:443
# REALITY_DEST=...   # alias для REALITY_TARGET
# REALITY_SNI=www.yahoo.com,yahoo.com
# REALITY_FP=firefox

# --- Опционально: порты для документации/UFW ---
# VLESS_REALITY_PORT=443
# SOCKS_PORT=10808
# HYSTERIA2_PORT=8444

# --- Community geofiles (scripts/setup-geofiles.sh) ---
# GEOSITE_RU_URL=https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/geosite.dat
# GEOIP_RU_BLOCKED_URL=https://raw.githubusercontent.com/runetfreedom/russia-blocked-geoip/release/ru-blocked.dat
